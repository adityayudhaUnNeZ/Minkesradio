{
  "name": "minkes-radio",
  "version": "1.0.0",
  "private": true,
  "description": "Minkes Radio web (Express + Tailwind)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/assets/styles.css",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/assets/styles.css --watch",
    "dev": "concurrently -k \"npm:watch:css\" \"nodemon server.js\""
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10"
  }
}

